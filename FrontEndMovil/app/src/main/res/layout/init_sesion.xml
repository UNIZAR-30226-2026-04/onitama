<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/azulFondo">
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/main_background" />

    <View
        android:id="@+id/v_gradient_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/fading_blue"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <ImageView
            android:layout_width="346dp"
            android:layout_height="79dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="50dp"
            android:scaleType="fitCenter"
            android:src="@drawable/onitama_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/quattrocento_bold"
            android:scaleType="fitCenter"
            android:text="INICIO DE SESIÓN"
            android:textColor="#E8E8E8"
            android:textSize="40dp"></TextView>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="19dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/quattrocento_bold"
            android:scaleType="fitCenter"
            android:text="Introduce tu correo o nombre de usuario:"
            android:textColor="#E8E8E8"
            android:textSize="19dp"></TextView>

        <EditText
            android:id="@+id/IniSesUsr"
            android:layout_width="380dp"
            android:layout_height="48dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:background="@drawable/campo_texto"
            android:text="ejemplo@correo.com/ejemplodeusuario"
            android:textColor="#B8B7B7"
            android:fontFamily="@font/quattrocento_bold"></EditText>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="19dp"
            android:layout_marginTop="50dp"
            android:layout_marginRight="10dp"
            android:fontFamily="@font/quattrocento_bold"
            android:scaleType="fitCenter"
            android:text="Introduce tu contraseña:"
            android:textColor="#E8E8E8"
            android:textSize="20dp"></TextView>

        <EditText
            android:id="@+id/IniSesPwd"
            android:layout_width="380dp"
            android:layout_height="48dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:background="@drawable/campo_texto"
            android:textColor="#B8B7B7"
            android:fontFamily="@font/quattrocento_bold"></EditText>
        <TextView
            android:id="@+id/olvidarPwd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="80dp"
            android:layout_marginRight="80dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/quattrocento_bold"
            android:scaleType="fitCenter"
            android:text="¿Olvidaste tu contraseña?"
            android:textColor="#3e63ff"
            android:textSize="20dp"
            android:clickable="true"></TextView>
        <Button
            android:id="@+id/btn_login"
            android:layout_marginTop="40dp"
            android:layout_width="180dp"
            android:layout_height="60dp"
            android:layout_marginLeft="110dp"
            android:layout_marginRight="110dp"
            android:background="@drawable/boton_esquinas_redondas"
            android:text="CONTINUAR"
            android:textSize="20dp"
            android:fontFamily="@font/quattrocento_bold"></Button>
        <TextView
            android:id="@+id/notAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="70dp"
            android:layout_marginRight="70dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/quattrocento_bold"
            android:scaleType="fitCenter"
            android:text="¿No tienes cuenta? Registrate"
            android:textColor="#3e63ff"
            android:textSize="20dp"
            android:clickable="true"></TextView>
    </LinearLayout>


</FrameLayout>